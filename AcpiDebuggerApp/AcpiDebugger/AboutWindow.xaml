<Window x:Class="AcpiDebugger.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About ACPI Debugger"
        Width="460" Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F7F8FA"
        FontFamily="Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="Accent" Color="#008C95"/>
        <SolidColorBrush x:Key="Border" Color="#D8DCE2"/>
        <SolidColorBrush x:Key="Muted" Color="#667085"/>
    </Window.Resources>

    <Grid Margin="18">
        <Border Background="White"
                BorderBrush="{StaticResource Border}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Border Width="52" Height="52" CornerRadius="10" Background="{StaticResource Accent}">
                        <TextBlock Text="AC" Foreground="White" FontSize="18" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="16,0,0,0">
                        <TextBlock Text="ACPI Debugger" FontSize="24" FontWeight="SemiBold" Foreground="#111827"/>
                        <TextBlock Text="Firmware ACPI development utility" Foreground="{StaticResource Muted}" Margin="0,5,0,0"/>
                    </StackPanel>
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,24,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Version" Foreground="{StaticResource Muted}"/>
                    <TextBlock Grid.Column="1" x:Name="VersionText"/>
                    <TextBlock Text="Build Date" Foreground="{StaticResource Muted}" Margin="0,35,0,0"/>
                    <TextBlock Grid.Column="1" x:Name="BuildDateText" Margin="0,35,0,0"/>
                    <TextBlock Text="Author" Foreground="{StaticResource Muted}" Margin="0,70,0,0"/>
                    <TextBlock Grid.Column="1" Text="bin" Margin="0,70,0,0"/>
                    <TextBlock Text="Blog" Foreground="{StaticResource Muted}" Margin="0,105,0,0"/>
                    <TextBlock Grid.Column="1" Margin="0,105,0,0"><Hyperlink Click="Blog_Click">https://ay123.net</Hyperlink></TextBlock>
                    <TextBlock Text="WeChat" Foreground="{StaticResource Muted}" Margin="0,140,0,0"/>
                    <TextBlock Grid.Column="1" Text="UEFI那点事" Margin="0,140,0,0"/>
                </Grid>

                <TextBlock Grid.Row="2" Text="© 2026 bin  |  UEFI / ACPI Development Tool"
                           HorizontalAlignment="Right"
                           Foreground="{StaticResource Muted}"/>
            </Grid>
        </Border>
    </Grid>
</Window>