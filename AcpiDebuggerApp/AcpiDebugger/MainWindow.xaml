<Window x:Class="AcpiDebugger.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="ACPI Debugger" Width="1440" Height="900" MinWidth="1120" MinHeight="680"
        Background="#F7F8FA" FontFamily="Segoe UI" FontSize="13"
        Closing="Window_Closing" PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <SolidColorBrush x:Key="Accent" Color="#008C95"/>
        <SolidColorBrush x:Key="AccentHover" Color="#007981"/>
        <SolidColorBrush x:Key="Border" Color="#D8DCE2"/>
        <SolidColorBrush x:Key="Muted" Color="#667085"/>
        <Style TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#20242A"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource Accent}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="ToolButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="1,0"/>
            <Setter Property="MinHeight" Value="32"/>
        </Style>
        <Style x:Key="ToolGroupTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style x:Key="DetailLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
            <Setter Property="Margin" Value="0,0,0,9"/>
        </Style>
        <Style x:Key="DetailValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#24272C"/>
            <Setter Property="Margin" Value="0,0,0,9"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="0"/>
            <RowDefinition Height="62"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- Product header -->
        <Border Grid.Row="0" Visibility="Collapsed" Background="White" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
            <Grid Margin="14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="24" Height="24" CornerRadius="3" Background="#173B57" VerticalAlignment="Center">
                    <TextBlock Text="AC" Foreground="White" FontSize="9" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock Grid.Column="1" Text="ACPI Debugger" FontSize="17" FontWeight="SemiBold" Margin="10,0,20,0" VerticalAlignment="Center"/>
                <Border Grid.Column="2" Background="{StaticResource Border}" Margin="0,10"/>
                <TextBlock Grid.Column="3" x:Name="MachineText" Text="Windows ACPI Workspace" FontSize="14" Margin="18,0" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" Fill="#16A34A" Margin="0,0,6,0"/>
                    <TextBlock Text="Elevated" VerticalAlignment="Center" Margin="0,0,22,0"/>
                    <Ellipse x:Name="TestModeDot" Width="8" Height="8" Fill="#16A34A" Margin="0,0,6,0"/>
                    <TextBlock x:Name="TestModeText" Text="Test Mode" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Command bar -->
        <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
            <Grid Margin="14,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0" Visibility="Collapsed" Margin="0,14,18,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/><ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="ASL" Style="{StaticResource PrimaryButton}" Margin="0"/>
                    <Button Grid.Column="1" Content="AML" Margin="0"/>
                </Grid>
                <Border Grid.Column="0" Visibility="Collapsed" Background="{StaticResource Border}" Margin="0,12"/>
                <StackPanel Grid.Column="0" x:Name="ToolbarPanel" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0">
                    <Button Style="{StaticResource ToolButton}" Content="↓ Dump" ToolTip="Dump ACPI tables" Click="DumpAml_Click"/>
                    <Button Style="{StaticResource ToolButton}" Content="⚙ Decompile" ToolTip="Decompile AML" Click="DecompileSelected_Click"/>
                    <Button Style="{StaticResource ToolButton}" Content="▶ Compile" ToolTip="Compile ASL" Click="CompileSelected_Click"/>
                    <Separator Margin="8,4"/>
                    <Button Style="{StaticResource ToolButton}" Content="📂 Open" Click="LoadToSystem_Click"/>
                    <Button Style="{StaticResource ToolButton}" Content="💾 Save" Click="Save_Click"/>
                    <Separator Margin="8,4"/>
                    <Button Style="{StaticResource ToolButton}" Content="⇩ Decompile All" Click="DecompileAll_Click"/>
                    <Button Style="{StaticResource ToolButton}" Content="⇧ Compile All" Click="CompileAll_Click"/>
                    <Separator Margin="8,4"/>
                    <Button Style="{StaticResource ToolButton}" Content="🔍 Find" Click="ShowFind_Click"/>
                    <Button Style="{StaticResource ToolButton}" Content="↪ Go Line" Click="GoToLine_Click"/>
                    <Separator Margin="8,10"/>
                    <Button Style="{StaticResource ToolButton}" Content="ⓘ About" Click="About_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Workbench -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="272" MinWidth="210"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="292" MinWidth="230"/>
            </Grid.ColumnDefinitions>

            <!-- Explorer -->
            <Border Grid.Column="0" Background="#FBFCFD" BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="58"/>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="36"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Margin="13,12,13,8" BorderBrush="#C9CED6" BorderThickness="1" CornerRadius="3" Background="White">
                        <DockPanel>
                            <TextBlock Text="⌕" FontSize="17" Margin="10,0,6,0" VerticalAlignment="Center" Foreground="{StaticResource Muted}"/>
                            <TextBox x:Name="TableSearchBox" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center"
                                     TextChanged="TableSearchBox_TextChanged" ToolTip="Search tables"/>
                        </DockPanel>
                    </Border>
                    <TextBlock Grid.Row="1" Text="ACPI TABLES" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource Muted}" Margin="14,4,0,0"/>
                    <Grid Grid.Row="2">
                        <TreeView x:Name="TableTree" BorderThickness="0" Background="Transparent"
                                  Padding="4,0,4,4" SelectedItemChanged="TableTree_SelectedItemChanged">
                            <TreeView.Resources>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="IsExpanded" Value="True"/>
                                    <Setter Property="Padding" Value="4,5"/>
                                    <Setter Property="Margin" Value="0,1"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <EventSetter Event="PreviewMouseLeftButtonDown" Handler="TableTreeItem_PreviewMouseLeftButtonDown"/>
                                </Style>
                            </TreeView.Resources>
                        </TreeView>
                        <ListBox x:Name="AmlList" Visibility="Collapsed" SelectionChanged="AmlList_SelectionChanged"/>
                        <ListBox x:Name="AslList" Visibility="Collapsed" SelectionChanged="AslList_SelectionChanged"/>
                    </Grid>
                    <Border Grid.Row="3" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
                        <DockPanel Margin="13,0">
                            <TextBlock x:Name="TableCountText" Text="0 tables" VerticalAlignment="Center" Foreground="{StaticResource Muted}"/>
                            <Button Content="↻" DockPanel.Dock="Right" Width="30" Padding="0" Margin="0" BorderThickness="0" Click="Refresh_Click"/>
                        </DockPanel>
                    </Border>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="#E5E7EB"/>

            <!-- Editor and diagnostics -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="34"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="210" MinHeight="100"/>
                </Grid.RowDefinitions>

                <Border x:Name="FindBar" Grid.Row="0" Background="#F8FAFC" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="8" Visibility="Collapsed">
                    <WrapPanel>
                        <TextBox x:Name="FindTextBox" Width="190" Height="30" Padding="7,0"
                                 VerticalContentAlignment="Center" ToolTip="Find" KeyDown="FindTextBox_KeyDown"/>
                        <TextBox x:Name="ReplaceTextBox" Width="170" Height="30" Padding="7,0" Margin="8,0,0,0"
                                 VerticalContentAlignment="Center" ToolTip="Replace with"/>
                        <Button Content="Previous" Margin="8,0,6,0" Padding="10,5" Click="FindPrevious_Click"/>
                        <Button Content="Next" Margin="0,0,6,0" Padding="10,5" Click="FindNext_Click"/>
                        <Button Content="Replace" Margin="0,0,6,0" Padding="10,5" Click="Replace_Click"/>
                        <Button Content="Replace All" Margin="0,0,6,0" Padding="10,5" Click="ReplaceAll_Click"/>
                        <Button Content="Find All Files" Margin="0,0,6,0" Padding="10,5" Click="FindAllFiles_Click"/>
                        <Button Content="Close" Margin="0" Padding="10,5" Click="CloseFind_Click"/>
                        <TextBlock x:Name="FindResultText" Margin="10,6,0,0" Foreground="{StaticResource Muted}"/>
                    </WrapPanel>
                </Border>

                <Border Grid.Row="1" Background="#FAFBFC" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                    <DockPanel>
                        <Border BorderBrush="{StaticResource Accent}" BorderThickness="0,0,0,2" Padding="15,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="EditorTabText" Text="No file open" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <Ellipse x:Name="DirtyDot" Width="7" Height="7" Fill="{StaticResource Accent}" Margin="8,0,0,0" Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>
                    </DockPanel>
                </Border>

                <avalonEdit:TextEditor x:Name="Editor" Grid.Row="2"
                                       FontFamily="Cascadia Mono,Consolas" FontSize="14"
                                       ShowLineNumbers="True" WordWrap="False"
                                       HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                       Background="White" Foreground="#20242A"
                                       LineNumbersForeground="#2387A5"
                                       TextChanged="Editor_TextChanged"/>

                <GridSplitter Grid.Row="3" HorizontalAlignment="Stretch" Background="#D8DCE2"/>

                <TabControl Grid.Row="4" x:Name="BottomTabs" BorderThickness="0,1,0,0" BorderBrush="{StaticResource Border}">
                    <TabItem Header="Diagnostics">
                        <DataGrid x:Name="DiagnosticsGrid" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal" BorderThickness="0" RowHeaderWidth="0"
                                  MouseDoubleClick="DiagnosticsGrid_MouseDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="90"/>
                                <DataGridTextColumn Header="File" Binding="{Binding File}" Width="120"/>
                                <DataGridTextColumn Header="Line" Binding="{Binding Line}" Width="65"/>
                                <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                                <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                    <TabItem x:Name="OutputTab" Header="Output">
                        <RichTextBox x:Name="OutputBox" IsReadOnly="True" FontFamily="Cascadia Mono,Consolas" FontSize="13"
                                     Background="White" Foreground="#1F2937" BorderThickness="0"
                                     VerticalScrollBarVisibility="Auto" MouseDoubleClick="OutputBox_MouseDoubleClick"/>
                    </TabItem>
                    <TabItem x:Name="SearchResultsTab" Header="Search Results">
                        <DataGrid x:Name="SearchResultsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal" BorderThickness="0"
                                  RowHeaderWidth="0" MouseDoubleClick="SearchResultsGrid_MouseDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="File" Binding="{Binding File}" Width="150"/>
                                <DataGridTextColumn Header="Line" Binding="{Binding Line}" Width="70"/>
                                <DataGridTextColumn Header="Text" Binding="{Binding Preview}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                </TabControl>
            </Grid>

            <GridSplitter Grid.Column="3" HorizontalAlignment="Stretch" Background="#E5E7EB"/>

            <!-- Details -->
            <Border Grid.Column="4" Background="#FBFCFD" BorderBrush="{StaticResource Border}" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="44"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                        <TextBlock Text="Table Details" FontSize="14" FontWeight="SemiBold" Margin="15,0" VerticalAlignment="Center"/>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="104"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Signature" Style="{StaticResource DetailLabel}"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="DetailSignature" Text="—" Style="{StaticResource DetailValue}"/>
                            <TextBlock Grid.Row="1" Text="Description" Style="{StaticResource DetailLabel}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="DetailDescription" Text="Select a table" TextWrapping="Wrap" Style="{StaticResource DetailValue}"/>
                            <TextBlock Grid.Row="2" Text="OEM ID" Style="{StaticResource DetailLabel}"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="DetailOemId" Text="—" Style="{StaticResource DetailValue}"/>
                            <TextBlock Grid.Row="3" Text="OEM Table ID" Style="{StaticResource DetailLabel}"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="DetailTableId" Text="—" Style="{StaticResource DetailValue}"/>
                            <TextBlock Grid.Row="4" Text="OEM Revision" Style="{StaticResource DetailLabel}"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="DetailOemRevision" Text="—" Style="{StaticResource DetailValue}"/>
                            <TextBlock Grid.Row="5" Text="Creator ID" Style="{StaticResource DetailLabel}"/>
                            <TextBlock Grid.Row="5" Grid.Column="1" x:Name="DetailCreatorId" Text="—" Style="{StaticResource DetailValue}"/>
                            <TextBlock Grid.Row="6" Text="Creator Rev." Style="{StaticResource DetailLabel}"/>
                            <TextBlock Grid.Row="6" Grid.Column="1" x:Name="DetailCreatorRevision" Text="—" Style="{StaticResource DetailValue}"/>
                            <TextBlock Grid.Row="7" Text="Revision" Style="{StaticResource DetailLabel}"/>
                            <TextBlock Grid.Row="7" Grid.Column="1" x:Name="DetailRevision" Text="—" Style="{StaticResource DetailValue}"/>
                            <TextBlock Grid.Row="8" Text="Length" Style="{StaticResource DetailLabel}"/>
                            <TextBlock Grid.Row="8" Grid.Column="1" x:Name="DetailLength" Text="—" Style="{StaticResource DetailValue}"/>
                            <TextBlock Grid.Row="9" Text="Checksum" Style="{StaticResource DetailLabel}"/>
                            <TextBlock Grid.Row="9" Grid.Column="1" x:Name="DetailChecksum" Text="—" Style="{StaticResource DetailValue}"/>
                            <TextBlock Grid.Row="10" Text="Source" Style="{StaticResource DetailLabel}"/>
                            <TextBlock Grid.Row="10" Grid.Column="1" x:Name="DetailSource" Text="—" TextWrapping="Wrap" Style="{StaticResource DetailValue}"/>
                            <TextBlock Grid.Row="11" Text="Validated" Style="{StaticResource DetailLabel}"/>
                            <TextBlock Grid.Row="11" Grid.Column="1" x:Name="DetailValidated" Text="—" Style="{StaticResource DetailValue}"/>
                        </Grid>
                    </ScrollViewer>
                    <Border Grid.Row="2" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="15">
                        <StackPanel>
                            <TextBlock Text="Override" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBlock Text="Load this table as an override in Windows test mode." Foreground="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,12"/>
                            <Button Content="Load override…" Margin="0" Click="LoadToSystem_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <StatusBar Grid.Row="3" Background="White" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="7,0">
            <StatusBarItem><TextBlock x:Name="StatusText" Text="Ready"/></StatusBarItem>
            <StatusBarItem>
                <ProgressBar x:Name="BatchProgress" Width="150" Height="12" Visibility="Collapsed"/>
            </StatusBarItem>
            <StatusBarItem>
                <Button x:Name="CancelBatchButton" Content="Cancel" Padding="8,1" MinHeight="20" Margin="4,0,0,0"
                        Visibility="Collapsed" Click="CancelBatch_Click"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem><TextBlock x:Name="ToolStatusText" Text="Tools" Foreground="{StaticResource Muted}"/></StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right"><TextBlock x:Name="PositionText" Text="Ln 1, Col 1"/></StatusBarItem>
            <Separator/><StatusBarItem><TextBlock Text="Spaces: 4"/></StatusBarItem>
            <Separator/><StatusBarItem><TextBlock Text="UTF-8"/></StatusBarItem>
            <Separator/><StatusBarItem><TextBlock Text="ASL"/></StatusBarItem>
            <Separator/><StatusBarItem><TextBlock Text="AvalonEdit"/></StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="7" Height="7" Fill="#16A34A" Margin="0,0,5,0"/>
                    <TextBlock Text="Elevated" Margin="0,0,16,0"/>
                    <Ellipse x:Name="BottomTestModeDot" Width="7" Height="7" Fill="#16A34A" Margin="0,0,5,0"/>
                    <TextBlock x:Name="BottomTestModeText" Text="Test Mode"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
